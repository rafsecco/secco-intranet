@model SetorFormViewModel
@{
    ViewData["Title"] = "Novo setor";
}
<h1>Novo setor</h1>

<div asp-validation-summary="ModelOnly" class="validation-summary"></div>

<form method="post" asp-action="Create">
    <div class="form-group">
        <label asp-for="Nome"></label>
        <input asp-for="Nome" />
        <span asp-validation-for="Nome" class="field-validation"></span>
    </div>
    <div class="form-group">
        <label asp-for="Slug"></label>
        <input asp-for="Slug" />
        <span asp-validation-for="Slug" class="field-validation"></span>
    </div>
    <div class="form-group form-check">
        <label asp-for="Fixo"></label>
        <input asp-for="Fixo" />
    </div>
    <button type="submit">Criar</button>
</form>

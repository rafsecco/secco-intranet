# Gitignore para repositório Secco.Intranet
# Baseado em VisualStudio official template, adaptado para .NET 9 Clean Architecture

# ============================================================================
# BUILD E ARTEFATOS
# ============================================================================
bin/
obj/
artifacts/
[Dd]ebug/
[Rr]elease/
out/

# ============================================================================
# VISUAL STUDIO
# ============================================================================
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# ============================================================================
# RIDER / INTELLIJ
# ============================================================================
.idea/
*.sln.iml

# ============================================================================
# VISUAL STUDIO CODE
# ============================================================================
# Ignorar toda pasta .vscode
.vscode/*

# Exceto configurações compartilhadas no time
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ============================================================================
# TESTES E COBERTURA DE CÓDIGO
# ============================================================================
TestResults/
coverage*/
*.trx
*.coverage
*.coveragexml

# ============================================================================
# NUGET
# ============================================================================
*.nupkg
*.snupkg
packages/
project.lock.json

# ============================================================================
# PUBLICAÇÃO E DEPLOY
# ============================================================================
publish/
*.pubxml.user
# Nota: não ignorar *.pubxml em si, apenas *.pubxml.user (arquivo local)

# ============================================================================
# SEGREDOS LOCAIS (NÃO VERSIONADOS)
# ============================================================================
appsettings.*.local.json
*.env
.env
.env.*
secrets.json
# Nota: appsettings.json e appsettings.Development.json SÃO versionados

# ============================================================================
# BANCO DE DADOS LOCAL
# ============================================================================
*.db
*.db-shm
*.db-wal
*.mdf
*.ldf

# ============================================================================
# SISTEMA OPERACIONAL
# ============================================================================
Thumbs.db
Desktop.ini
.DS_Store

# ============================================================================
# LOGS
# ============================================================================
*.log
logs/

# ============================================================================
# NOTA: .claude/ É VERSIONADO
# ============================================================================
# A pasta .claude/ contém configurações e deve ser versionada no repositório
